rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Document ID: uid
    // Fields: uid, name, email, role, createdAt
    //
    // Collection: products
    // Document ID: productId
    // Fields: id, name, price, image, description, createdAt
    //
    // Collection: order
    // Document ID: orderId
    // Fields: orderId, userId, name, email, phone, address, products, total, status, createdAt
    //
    // Collection: wishlist
    // Document ID: wishlistId
    // Fields: userId, productId, name, price, image
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "aroshiarya22@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'email', 'role', 'createdAt']) &&
             data.uid is string && data.name is string && data.email is string &&
             data.role in ['user', 'admin'] && data.createdAt is string;
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['id', 'name', 'price', 'image', 'description', 'category', 'createdAt']) &&
             data.id is string && data.name is string && data.price is number &&
             data.image is string && data.description is string && data.category is string && data.createdAt is string;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['orderId', 'userId', 'name', 'email', 'phone', 'address', 'products', 'total', 'status', 'createdAt']) &&
             data.orderId is string && data.userId is string && data.name is string &&
             data.email is string && data.phone is string && data.address is string &&
             data.products is list && data.total is number &&
             data.status in ['pending', 'shipped', 'delivered', 'cancelled'] && data.createdAt is string &&
             (!('rating' in data) || (data.rating is number && data.rating >= 1 && data.rating <= 5));
    }

    function isValidWishlistItem(data) {
      return data.keys().hasAll(['userId', 'productId', 'name', 'price', 'image']) &&
             data.userId is string && data.productId is string &&
             data.name is string && data.price is number && data.image is string;
    }

    // Rules
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && 
                    ((isOwner(userId) && request.resource.data.role == 'user') || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && 
                    ((isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin());
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin() && isValidProduct(request.resource.data);
    }

    match /order/{orderId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && isValidOrder(request.resource.data) && 
                    (request.resource.data.userId == request.auth.uid || isAdmin());
      allow update: if (isAdmin() && isValidOrder(request.resource.data)) || 
                    (isAuthenticated() && resource.data.userId == request.auth.uid && 
                     isValidOrder(request.resource.data) &&
                     request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'rating']) &&
                     (request.resource.data.status == resource.data.status || (resource.data.status == 'pending' && request.resource.data.status == 'cancelled')));
      allow delete: if isAdmin();
    }

    match /wishlist/{wishlistId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && isValidWishlistItem(request.resource.data) && 
                    request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
  }
}
